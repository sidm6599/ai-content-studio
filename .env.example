# Copy to .env and fill in at least one provider key (optional — app runs in mock mode without keys).

# Provider selection: auto | gemini | openrouter | nvidia | mock
LLM_PROVIDER=auto

# Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenRouter fallback (https://openrouter.ai/keys) — free Llama/Nemotron models
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# NVIDIA NIM (https://build.nvidia.com) — OpenAI-compatible. Models, fast→strong:
# meta/llama-3.2-1b-instruct (fastest), meta/llama-3.1-8b-instruct, meta/llama-3.3-70b-instruct
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.2-1b-instruct

# Generation
TEMPERATURE=0.7
MAX_GENERATIONS=5

# RAG / embeddings
EMBED_MODEL=all-MiniLM-L6-v2
VECTOR_BACKEND=memory   # memory | chromadb | supabase

# Supabase persistence (optional — history won't be forgotten across refreshes)
# Project Settings → API: URL + anon/service key. Run supabase/schema.sql first.
SUPABASE_URL=
SUPABASE_KEY=
PERSIST_HISTORY=true
